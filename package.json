{
  "name": "iobroker.govee-smart",
  "version": "2.15.0",
  "description": "Control Govee WiFi devices via LAN, MQTT and Cloud.",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "role": "Coding assistance"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.govee-smart",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "govee",
    "smart home",
    "led",
    "light",
    "sensor",
    "thermometer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.govee-smart"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/iobroker": "npm:@iobroker/types@^7.1.2",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.8",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/lib/**/*.{js,js.map}",
    "build/main.js",
    "build/main.js.map",
    "devices.json",
    "devices.schema.json",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:ts": "vitest run",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "translate": "translate-adapter",
    "release": "release-script",
    "validate-devices": "ts-node --project tools/tsconfig.json tools/validate-devices.ts",
    "gen-wiki": "ts-node --project tools/tsconfig.json tools/gen-wiki-devices.ts"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.govee-smart/issues"
  }
}
